{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Funeral Readings Planner",
  "version": "1.0.0",
  "identifier": "io.github.fr-peter.funeral-readings-planner",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build && npm run preview -- --port 1420 --strictPort",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Funeral Readings Planner",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "dmg"],
    "category": "Utility",
    "shortDescription": "Catholic funeral liturgy reading selection and print",
    "longDescription": "A local, offline planner for selecting readings for the Catholic funeral liturgy and producing print-quality output.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
